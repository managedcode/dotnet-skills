{
  "id": "dotnet-skills",
  "repository": "https://github.com/dotnet/skills",
  "sourceRoot": "upstreams/dotnet-skills",
  "docsBase": "https://github.com/dotnet/skills/tree/main/plugins",
  "titlePrefix": "Official .NET skills",
  "managedPackagePrefix": "Official-DotNet",
  "replaceSkillConflicts": true,
  "replaceAgentConflicts": true,
  "pluginDefaults": {
    "type": "Platform",
    "category": "Core",
    "compatibility": "Requires a .NET repository or solution."
  },
  "pluginOverrides": {
    "dotnet-ai": {
      "category": "AI",
      "compatibility": "Requires a .NET repository working with AI, ML, or MCP workloads.",
      "skillOverrides": {
        "mcp-csharp-create": {
          "exclude": true
        },
        "mcp-csharp-debug": {
          "exclude": true
        },
        "mcp-csharp-publish": {
          "exclude": true
        },
        "mcp-csharp-test": {
          "exclude": true
        }
      }
    },
    "dotnet-aspnet": {
      "type": "Frameworks",
      "category": "Web",
      "compatibility": "Requires an ASP.NET Core project or solution.",
      "skillOverrides": {
        "configuring-opentelemetry-dotnet": {
          "package_prefix": "OpenTelemetry"
        },
        "minimal-api-file-upload": {
          "package_prefix": "Microsoft.AspNetCore"
        }
      }
    },
    "dotnet-data": {
      "type": "Libraries",
      "category": "Data",
      "compatibility": "Requires a .NET repository using Entity Framework Core or similar data-access patterns.",
      "skillOverrides": {
        "optimizing-ef-core-queries": {
          "package_prefix": "Microsoft.EntityFrameworkCore"
        }
      }
    },
    "dotnet-diag": {
      "type": "Tools",
      "package": "Official-DotNet-Diagnostics",
      "category": "Metrics",
      "compatibility": "Requires a .NET repository, build artifacts, traces, dumps, or a runnable app for diagnostics work."
    },
    "dotnet-experimental": {
      "category": "Testing",
      "compatibility": "Requires a .NET repository where experimental upstream dotnet/skills guidance is acceptable.",
      "skillOverrides": {
        "exp-simd-vectorization": {
          "category": "Core"
        }
      }
    },
    "dotnet-maui": {
      "type": "Frameworks",
      "package": "Official-DotNet-MAUI",
      "category": "Cross-Platform UI",
      "compatibility": "Requires a .NET MAUI project or solution.",
      "skillDefaults": {
        "package_prefix": "Microsoft.Maui"
      }
    },
    "dotnet-msbuild": {
      "type": "Tools",
      "compatibility": "Requires a .NET repository with MSBuild project or solution files."
    },
    "dotnet-nuget": {
      "type": "Tools",
      "compatibility": "Requires a .NET repository using NuGet package management."
    },
    "dotnet-template-engine": {
      "type": "Tools",
      "compatibility": "Requires a .NET repository using dotnet new templates or template authoring workflows."
    },
    "dotnet-test": {
      "type": "Testing",
      "category": "Testing",
      "compatibility": "Requires a .NET test project or solution.",
      "skillOverrides": {
        "coverage-analysis": {
          "packages": [
            "coverlet.collector",
            "coverlet.msbuild"
          ]
        },
        "migrate-mstest-v1v2-to-v3": {
          "package_prefix": "MSTest"
        },
        "migrate-mstest-v3-to-v4": {
          "package_prefix": "MSTest"
        },
        "migrate-xunit-to-xunit-v3": {
          "packages": [
            "xunit",
            "xunit.v3"
          ]
        },
        "writing-mstest-tests": {
          "package_prefix": "MSTest"
        }
      }
    },
    "dotnet-upgrade": {
      "category": "Legacy",
      "compatibility": "Requires a .NET repository being migrated across framework, SDK, or compatibility changes."
    }
  }
}
