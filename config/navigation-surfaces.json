        "hotKey": "1",
        "action": "BrowsePackages",
        "summary": "NuGet ids and prefixes -> skills",
        "command": "dotnet skills install --auto",
        "accent": "turquoise2"
      }
    },
    {
      "id": "bundles",
      "label": "Bundles",
      "href": "bundles/",
      "cli": {
        "hotKey": "2",
